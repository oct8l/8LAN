# Copy this file to .env and fill in your local values.
# .env is gitignored and used by local helper scripts.

# Required for remote Windows sync/build helpers.
WIN_USER=your_windows_username
WIN_HOST=your_windows_host_or_ip
WIN_PASS=your_windows_password

# Optional paths.
WIN_DIR=/c/dlan-work
# WIN_DESKTOP_DIR=/c/Users/your_windows_username/Desktop
# WIN_DESKTOP_NAME=D-LAN-portable
